# =============================================================================
# Serveur TTS GPU — MOSS-TTS-v1.5
# =============================================================================
# Cles API acceptees (separees par des virgules). VIDE = AUCUNE AUTH :
# uniquement acceptable sur un LAN/VPN de confiance. A mettre en prod LAN.
TTS_SERVER_API_KEYS=change-me

# Modele servi par ce container. Un container = un modele garde chaud en VRAM.
TTS_SERVER_MODEL=OpenMOSS-Team/MOSS-TTS-v1.5

# auto detecte cuda > mps > cpu. Sur le serveur GPU, laisser auto.
TTS_SERVER_DEVICE=auto
# auto = bf16 (le checkpoint est BF16 ; ~16-18 Go de VRAM, OK pour >= 24 Go).
TTS_SERVER_DTYPE=auto

# Retention : les jobs termines (WAV inclus) sont purges apres ce delai ;
# le cache de WAV par contenu est purge apres N jours (0 = jamais).
TTS_SERVER_JOB_TTL_HOURS=48
TTS_SERVER_CACHE_TTL_DAYS=30

# Garde-fous par requete (defauts raisonnables).
# TTS_SERVER_MAX_SEGMENTS=64
# TTS_SERVER_MAX_TEXT_CHARS=2000
# TTS_SERVER_MAX_REFERENCE_MB=32
# TTS_SERVER_MAX_NEW_TOKENS=4096

# 1 = moteur factice (WAV silencieux, sans torch) pour tester l'API sans GPU.
# TTS_SERVER_FAKE_ENGINE=0

TTS_SERVER_LOG_LEVEL=INFO

# Token Hugging Face, seulement si le modele devient prive/gated.
# HF_TOKEN=
