# =============================================================================
# OBLIGATOIRE — endpoint LLM compatible OpenAI
# =============================================================================
# Le worker NE generera du Manim libre (scenes variees, LaTeX) que s'il peut
# parler a un vrai LLM. Sans cle / en mode fake, tout retombe en deterministe.
OPENAI_BASE_URL=http://host.docker.internal:8000/v1
OPENAI_API_KEY=change-me
OPENAI_MODEL=local-model

# Doit rester 0 en production. A 1, aucun appel LLM => blueprint canne + scenes
# deterministes uniquement (utile seulement pour tester le pipeline sans LLM).
VIDEO_API_FAKE_LLM=0

# =============================================================================
# SCENE CODER — le LLM ecrit le vrai Manim par scene (cause de la variete)
# =============================================================================
# 1 = active (defaut). 0 = force l'ancien mode 100% deterministe (cartes).
VIDEO_API_SCENE_CODER_ENABLED=1
# Modele qui ECRIT le code Manim. Vide => reutilise OPENAI_MODEL.
# Mettre ici un modele fort en code si OPENAI_MODEL est faible en Python,
# sinon beaucoup de scenes retomberont en fallback deterministe.
VIDEO_API_SCENE_CODER_MODEL=
# Tentatives (generation + reparations) par scene avant fallback. Defaut 3.
VIDEO_API_SCENE_CODER_ATTEMPTS=3
# Si OpenRouter / un modele reasoning renvoie du contenu vide, augmenter ce budget.
VIDEO_API_SCENE_CODER_MAX_TOKENS=4096

# =============================================================================
# REVUE VISUELLE (optionnel) — note les frames avec un modele vision
# =============================================================================
# 0 = desactive (defaut). Met 1 + un modele vision pour activer.
VIDEO_API_VISION_ENABLED=0
VIDEO_API_VISION_MODEL=          # ex: qwen2-vl — meme endpoint que OPENAI_BASE_URL
VIDEO_API_VISION_MIN_SCORE=75    # seuil /100, defaut 75
VIDEO_API_VISION_MAX_TOKENS=1500 # defaut 1500

# =============================================================================
# VOIX — Chatterbox local par defaut, ou TTS OpenAI-compatible optionnel
# =============================================================================
# chatterbox = Chatterbox principal non-turbo local (defaut)
# openai = appelle /audio/speech sur le meme OPENAI_BASE_URL
VIDEO_API_VOICE_ENGINE=chatterbox

# Pour utiliser un modele TTS servi par OPENAI_BASE_URL:
# VIDEO_API_VOICE_ENGINE=openai
# VIDEO_API_OPENAI_TTS_MODEL=tts-1       # remplace par le nom expose par ton serveur
# # OpenRouter, exemple actuel: openai/gpt-4o-mini-tts-2025-12-15
# VIDEO_API_OPENAI_TTS_VOICE=alloy       # remplace par une voix supportee par ton serveur
# VIDEO_API_OPENAI_TTS_FORMAT=wav        # wav conseille pour durations.json
# VIDEO_API_OPENAI_TTS_SPEED=1.0
# VIDEO_API_VOICE_TAIL_PADDING=0.45

# =============================================================================
# Reglages generaux (defauts raisonnables — a changer seulement si besoin)
# =============================================================================
VIDEO_API_MAX_REPAIR_ATTEMPTS=2          # reparations du blueprint complet
VIDEO_API_WORKER_CONCURRENCY=1           # 1 conseille (Chatterbox/Manim lourds)
VIDEO_API_LOG_LEVEL=INFO

# --- Tuning LLM blueprint (decommente si ton endpoint en a besoin) ---
# VIDEO_API_LLM_TEMPERATURE=0.35
# VIDEO_API_LLM_MAX_TOKENS=8000
# VIDEO_API_LLM_TIMEOUT_SECONDS=180
# VIDEO_API_LLM_RESPONSE_FORMAT=json_object   # mettre "text" si json_object non supporte
# Modeles "reasoning" (Qwen3...) : laisser 0 sinon le budget part dans <think>.
# VIDEO_API_LLM_ENABLE_THINKING=0

# --- Duree / rendu ---
# VIDEO_API_DEFAULT_TARGET_DURATION_SECONDS=240
# VIDEO_API_COMMAND_TIMEOUT_SECONDS=14400      # 4h : Chatterbox + rendu final 1080p60
