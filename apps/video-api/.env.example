# =============================================================================
# OBLIGATOIRE — endpoint LLM compatible OpenAI
# =============================================================================
# Le worker NE generera du Manim libre (scenes variees, LaTeX) que s'il peut
# parler a un vrai LLM. Sans cle / en mode fake, tout retombe en deterministe.
OPENAI_BASE_URL=http://host.docker.internal:8000/v1
OPENAI_API_KEY=change-me
OPENAI_MODEL=local-model

# Doit rester 0 en production. A 1, aucun appel LLM => blueprint canne + scenes
# deterministes uniquement (utile seulement pour tester le pipeline sans LLM).
VIDEO_API_FAKE_LLM=0

# =============================================================================
# MOTEUR DE RENDU — Manim (defaut) ou Remotion (React)
# =============================================================================
# manim    = pipeline Python/Manim historique (defaut, zero regression).
# remotion = moteur React/Remotion : le LLM compose une palette de composants
#            testes (Title/Bullet/Formula/Code/Plot/Diagram) + escape hatch code
#            libre par scene. Meme TTS Chatterbox, meme assemble, meme verify.
#            Necessite l'image avec Node + Chrome headless (deja dans le Dockerfile).
# Doc : apps/video-api/docs/remotion-engine.md
VIDEO_API_RENDER_ENGINE=manim
# (optionnel) chemin du projet Remotion partage. Defaut: <repo>/apps/video-api/remotion.
# VIDEO_API_REMOTION_DIR=

# =============================================================================
# SCENE CODER — le LLM ecrit le vrai code par scene (cause de la variete)
# =============================================================================
# S'applique aux DEUX moteurs : code Manim libre (manim) ou composant TSX libre
# pour les scenes "Custom" (remotion). 1 = active (defaut).
# 0 = manim -> templates deterministes ; remotion -> 100% palette testee.
VIDEO_API_SCENE_CODER_ENABLED=1
# Modele qui ECRIT le code Manim. Vide => reutilise OPENAI_MODEL.
# Mettre ici un modele fort en code si OPENAI_MODEL est faible en Python,
# sinon beaucoup de scenes retomberont en fallback deterministe.
VIDEO_API_SCENE_CODER_MODEL=
# Tentatives (generation + reparations) par scene avant fallback. Defaut 3.
VIDEO_API_SCENE_CODER_ATTEMPTS=3
# Si OpenRouter / un modele reasoning renvoie du contenu vide, augmenter ce budget.
VIDEO_API_SCENE_CODER_MAX_TOKENS=4096
# Prouver que chaque scene rend reellement avant de lui faire confiance, sinon
# fallback. manim : noms indefinis (symboles hallucines) + smoke render d'une frame.
# remotion : tsc --noEmit + smoke "remotion still" d'une frame de la scene Custom.
# 1 = actif (defaut). Tourne dans le worker (manim / node presents).
VIDEO_API_SCENE_CODER_SMOKE_RENDER=1
# Timeout (s) du smoke d'une scene. Defaut 150.
VIDEO_API_SCENE_CODER_SMOKE_TIMEOUT=150

# =============================================================================
# REVUE VISUELLE (optionnel) — note les frames avec un modele vision
# =============================================================================
# 0 = desactive (defaut). Met 1 + un modele vision pour activer.
VIDEO_API_VISION_ENABLED=0
VIDEO_API_VISION_MODEL=          # ex: qwen2-vl — meme endpoint que OPENAI_BASE_URL
VIDEO_API_VISION_MIN_SCORE=75    # seuil /100, defaut 75
VIDEO_API_VISION_MAX_TOKENS=1500 # defaut 1500

# =============================================================================
# VOIX — Chatterbox local par defaut, MOSS multilingue, ou TTS OpenAI-compatible
# =============================================================================
# chatterbox = Chatterbox principal non-turbo local (defaut, qualite max mais lent CPU)
# kokoro = TTS local ~5x plus rapide sur CPU, EN + FR (qualite solide, pas de clonage)
# moss = MOSS-TTS local/Hugging Face, multilingue, opt-in pour les langues europeennes
# openai = appelle /audio/speech sur le meme OPENAI_BASE_URL
VIDEO_API_VOICE_ENGINE=chatterbox

# Pour la voix rapide locale Kokoro (EN ou FR) :
# VIDEO_API_VOICE_ENGINE=kokoro
# VIDEO_API_VOICE_LANGUAGE=en            # en (lang_code "a") ou fr (lang_code "f")
# VIDEO_API_KOKORO_VOICE=af_bella        # voix Kokoro ; FR p.ex. ff_siwis
# (Kokoro a besoin du paquet systeme espeak-ng, deja installe dans le Dockerfile.)

# Pour utiliser MOSS-TTS multilingue :
# VIDEO_API_VOICE_ENGINE=moss
# VIDEO_API_MOSS_TTS_MODEL=OpenMOSS-Team/MOSS-TTS-v1.5
# VIDEO_API_MOSS_TTS_DEVICE=auto          # auto | cpu | cuda | mps
# VIDEO_API_MOSS_TTS_DTYPE=auto           # auto garde bf16 sur CPU/CUDA pour limiter la RAM
# VIDEO_API_MOSS_TTS_VOICE=               # optionnel, si le modele expose des voix nommees
# VIDEO_API_MOSS_TTS_REFERENCE_AUDIO=     # optionnel, zero-shot voice cloning si supporte
# VIDEO_API_MOSS_TTS_REFERENCE_TEXT=      # texte de la reference, si requis par le modele
# VIDEO_API_MOSS_TTS_CONSISTENT_VOICE=1   # reutilise la premiere scene comme reference pour stabiliser le timbre
# VIDEO_API_VOICE_TAIL_PADDING=0.45
# Si ton test local utilise une commande specifique, tu peux la reutiliser par segment :
# Pour une commande externe, ajouter {reference_audio} si le moteur accepte une reference de voix.
# VIDEO_API_MOSS_TTS_COMMAND='python -m moss_tts --model {model} --language {language} --text-file {text_file} --output {output}'

# Pour deporter MOSS-TTS sur le serveur GPU dedie (apps/tts-server) :
# le modele reste charge en VRAM la-bas, le worker n'envoie que les textes et
# telecharge les WAV. Si le serveur est injoignable, le job echoue clairement
# (pas de fallback de voix silencieux).
# VIDEO_API_VOICE_ENGINE=moss-remote
# VIDEO_API_TTS_SERVER_URL=http://<ip-serveur-gpu>:8100
# VIDEO_API_TTS_SERVER_API_KEY=change-me
# VIDEO_API_TTS_SERVER_TIMEOUT=3600        # attente max (s) du job TTS distant
# VIDEO_API_VOICE_LANGUAGE=en              # langue parlee, memes codes que moss
# VIDEO_API_MOSS_TTS_REFERENCE_AUDIO=      # optionnel: WAV de reference envoye au serveur
# VIDEO_API_MOSS_TTS_CONSISTENT_VOICE=1
# VIDEO_API_VOICE_TAIL_PADDING=0.45

# Pour utiliser un modele TTS servi par OPENAI_BASE_URL:
# VIDEO_API_VOICE_ENGINE=openai
# VIDEO_API_OPENAI_TTS_MODEL=tts-1       # remplace par le nom expose par ton serveur
# # OpenRouter, exemple actuel: openai/gpt-4o-mini-tts-2025-12-15
# VIDEO_API_OPENAI_TTS_VOICE=alloy       # remplace par une voix supportee par ton serveur
# VIDEO_API_OPENAI_TTS_FORMAT=wav        # wav conseille pour durations.json
# VIDEO_API_OPENAI_TTS_SPEED=1.0
# VIDEO_API_VOICE_TAIL_PADDING=0.45

# =============================================================================
# Reglages generaux (defauts raisonnables — a changer seulement si besoin)
# =============================================================================
VIDEO_API_MAX_REPAIR_ATTEMPTS=2          # reparations du blueprint complet
VIDEO_API_WORKER_CONCURRENCY=1           # 1 conseille (Chatterbox/Manim lourds)
VIDEO_API_LOG_LEVEL=INFO

# --- Retention des artefacts (workspaces /data/jobs/<id>) ---
# Les jobs terminaux dont le dossier a plus de JOB_TTL_DAYS sont supprimes ; la
# ligne en base est conservee (download/report -> 404 propre). Balayage au
# demarrage de l'API + periodiquement dans le worker (Celery beat). 0 = jamais.
VIDEO_API_JOB_TTL_DAYS=15                 # retention max en jours (0 = garder pour toujours)
VIDEO_API_GC_INTERVAL_HOURS=6            # cadence du GC periodique dans le worker

# --- Tuning LLM blueprint (decommente si ton endpoint en a besoin) ---
# VIDEO_API_LLM_TEMPERATURE=0.35
# VIDEO_API_LLM_MAX_TOKENS=8000
# VIDEO_API_LLM_TIMEOUT_SECONDS=180
# VIDEO_API_LLM_RESPONSE_FORMAT=json_object   # mettre "text" si json_object non supporte
# Modeles "reasoning" (Qwen3...) : laisser 0 sinon le budget part dans <think>.
# VIDEO_API_LLM_ENABLE_THINKING=0

# --- Duree / rendu ---
# VIDEO_API_DEFAULT_TARGET_DURATION_SECONDS=240
# VIDEO_API_COMMAND_TIMEOUT_SECONDS=14400      # 4h : Chatterbox + rendu final 1080p60

# --- Leviers vitesse du rendu Remotion (VM sans GPU, rendu CPU-bound) ---
# Toutes les passes (preview + final) en profitent. Sans effet sur le moteur Manim.
# fps de sortie : 30 (defaut) = ~2x moins de frames a encoder que 60 ; 60 = max fluidite.
# VIDEO_API_RENDER_FPS=30
# Concurrence Chrome du rendu : entier ou pourcentage. "75%" ~= 12 tabs sur 16 coeurs.
# ~0,5-1 Go par tab => sur 16 Go baisser a "50%" si le worker OOM.
# VIDEO_API_REMOTION_CONCURRENCY=75%
# Preset x264 du final : faster (defaut) accelere l'encodage, qualite ~identique a crf 18.
# VIDEO_API_RENDER_X264_PRESET=faster

# --- Garde "video figee" (final) ---
# Par defaut le gel est un AVERTISSEMENT, pas un echec : le MP4 est livre tant qu'il est
# techniquement valide (pistes video+audio, bonne resolution/fps, duree mini). Le detail du
# gel va dans report.json -> "quality_warnings" (+ reports/final/freeze.json). Tu regardes et
# tu juges. Mettre FATAL=1 pour rebloquer (job -> failed_quality si gel excessif).
# VIDEO_API_FREEZE_FATAL=0                  # 0 = livrer + avertir (defaut). 1 = bloquer.
# La garde utilise deux signaux : total cumule (tolerant) et plus long gel d'un seul tenant
# (strict) : declenche si total > max(FREEZE_FLOOR, duree*RATIO) OU un seul gel > SINGLE.
# Pour des videos tres "maths" (formules tenues longtemps), augmenter RATIO et/ou SINGLE.
# VIDEO_API_MAX_FREEZE_RATIO=0.5            # fraction de la duree toleree au total (defaut 0.5)
# VIDEO_API_FREEZE_FLOOR_SECONDS=30         # plancher du total tolere (defaut 30s)
# VIDEO_API_MAX_FREEZE_SINGLE_SECONDS=12    # plus long gel unique tolere (defaut 12s)
