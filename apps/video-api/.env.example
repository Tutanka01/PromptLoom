OPENAI_BASE_URL=http://host.docker.internal:8000/v1
OPENAI_API_KEY=change-me
OPENAI_MODEL=local-model

VIDEO_API_FAKE_LLM=0
VIDEO_API_MAX_REPAIR_ATTEMPTS=2
VIDEO_API_WORKER_CONCURRENCY=1

VIDEO_API_VISION_ENABLED=1
VIDEO_API_VISION_MODEL=qwen2-vl  # ou tout modèle vision sur ton endpoint
VIDEO_API_VISION_MIN_SCORE=75    # optionnel, défaut 75
VIDEO_API_VISION_MAX_TOKENS=3000  # optionnel, défaut 3000